{
  "id": "service_block",
  "type": "SharedSlice",
  "name": "ServiceBlock",
  "description": "Featured services block with title, subtitle, and repeatable selected services.",
  "variations": [
    {
      "id": "default",
      "name": "Default",
      "docURL": "...",
      "version": "sktwi1xtmkfgx8627",
      "description": "Default variation",
      "primary": {
        "badge_text": {
          "type": "Text",
          "config": {
            "label": "Badge Text",
            "placeholder": "Pakalpojumi"
          }
        },
        "title": {
          "type": "StructuredText",
          "config": {
            "label": "Title",
            "placeholder": "Augstākās klases zobārstniecība",
            "allowTargetBlank": true,
            "single": "heading2,heading3"
          }
        },
        "subtitle": {
          "type": "Text",
          "config": {
            "label": "Subtitle",
            "placeholder": "Pilns mūsdienīgu pakalpojumu spektrs..."
          }
        },
        "link_text": {
          "type": "Text",
          "config": {
            "label": "Link Text",
            "placeholder": "Skatīt visus pakalpojumus"
          }
        },
        "link_url": {
          "type": "Link",
          "config": {
            "label": "Link URL",
            "placeholder": "Select page or enter URL"
          }
        }
      },
      "items": {
        "service": {
          "type": "Link",
          "config": {
            "label": "Service Document",
            "select": "document",
            "customtypes": ["service"]
          }
        }
      }
