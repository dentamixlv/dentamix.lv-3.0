{
  "id": "widget_block",
  "type": "SharedSlice",
  "name": "WidgetBlock",
  "description": "Bio page block with customizable sidebar widgets.",
  "variations": [
    {
      "id": "default",
      "name": "Widget Detail",
      "docURL": "...",
      "version": "default",
      "description": "Renders a detailed bio profile page with dynamic sidebar widgets",
      "primary": {
        "image": {
          "type": "Image",
          "config": {
            "label": "Photo",
            "constraint": {},
            "thumbnails": []
          }
        },
        "workplace_title": {
          "type": "Text",
          "config": {
            "label": "Workplace Section Title",
            "placeholder": "Darba vieta"
          }
        },
        "cta_badge_text": {
          "type": "Text",
          "config": {
            "label": "CTA Badge Text",
            "placeholder": "Pieraksts atvērts"
          }
        },
        "cta_title": {
          "type": "Text",
          "config": {
            "label": "CTA Title",
            "placeholder": "Pieteikties uz vizīti"
          }
        },
        "cta_description": {
          "type": "Text",
          "config": {
            "label": "CTA Description",
            "placeholder": "Piesakieties vizītei vai konsultācijai..."
          }
        },
        "cta_button_text": {
          "type": "Text",
          "config": {
            "label": "CTA Button Text",
            "placeholder": "Pieteikties vizītei"
          }
        },
        "cta_link": {
          "type": "Link",
          "config": {
            "label": "CTA URL Link",
            "allowTargetBlank": true
          }
        },
        "cta_link_blank": {
          "type": "Boolean",
          "config": {
            "label": "Open CTA link in new tab",
            "default_value": false,
            "placeholder_true": "Yes",
            "placeholder_false": "No"
          }
        }
      },
      "items": {
        "widget_title": {
          "type": "Text",
          "config": {
            "label": "Widget Title",
            "placeholder": "e.g., Specialitātes, Izglītība"
          }
        },
        "widget_icon": {
          "type": "Text",
          "config": {
            "label": "Widget Icon (Lucide name)",
            "placeholder": "e.g., Award, GraduationCap, MapPin, Languages"
          }
        },
        "text": {
          "type": "Text",
          "config": {
            "label": "Text Content",
            "placeholder": "e.g., Zobu implantācija"
          }
        }
      }
    }
  ]
}
