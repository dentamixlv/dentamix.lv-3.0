{
  "id": "widget_block",
  "type": "SharedSlice",
  "name": "WidgetBlock",
  "description": "Bio page block with customizable sidebar widgets.",
  "variations": [
    {
      "id": "default",
      "name": "Widget Detail",
      "docURL": "...",
      "version": "default",
      "description": "Renders a detailed bio profile page with dynamic sidebar widgets",
      "primary": {
        "image": {
          "type": "Image",
          "config": {
            "label": "Photo",
            "constraint": {},
            "thumbnails": []
          }
        }
      },
      "items": {
        "widget_title": {
          "type": "Text",
          "config": {
            "label": "Widget Title",
            "placeholder": "e.g., Specialitātes, Izglītība"
          }
        },
        "widget_icon": {
          "type": "Text",
          "config": {
            "label": "Widget Icon (Lucide name)",
            "placeholder": "e.g., Award, GraduationCap, MapPin, Languages"
          }
        },
        "text": {
          "type": "StructuredText",
          "config": {
            "label": "Text Content",
            "placeholder": "e.g., Zobu implantācija",
            "single": "paragraph,strong,em,hyperlink"
          }
        }
      }
    }
  ]
}
