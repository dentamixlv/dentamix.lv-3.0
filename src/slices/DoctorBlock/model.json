{
  "id": "doctor_block",
  "type": "SharedSlice",
  "name": "DoctorBlock",
  "description": "Featured doctors block with title, subtitle, and repeatable selected doctors.",
  "variations": [
    {
      "id": "default",
      "name": "Doctor Detail",
      "docURL": "...",
      "version": "default",
      "description": "Renders a detailed profile page for a single doctor",
      "primary": {
        "fullBio": {
          "type": "StructuredText",
          "config": {
            "label": "Full Biography (Upper text with vertical line)",
            "placeholder": "Dr. Jānis Kalniņš ir augsti sertificēts...",
            "single": "paragraph,strong,em,hyperlink"
          }
        },
        "detailedBio": {
          "type": "StructuredText",
          "config": {
            "label": "Detailed Biography (Under doctor text)",
            "placeholder": "Enter detailed text like in a blog post...",
            "multi": "paragraph,preformatted,heading2,heading3,strong,em,hyperlink"
          }
        },
        "image": {
          "type": "Image",
          "config": {
            "label": "Photo",
            "constraint": {},
            "thumbnails": []
          }
        },
        "workplace_title": {
          "type": "Text",
          "config": {
            "label": "Workplace Section Title",
            "placeholder": "Darba vieta"
          }
        },
        "cta_badge_text": {
          "type": "Text",
          "config": {
            "label": "CTA Badge Text",
            "placeholder": "Pieraksts atvērts"
          }
        },
        "cta_title": {
          "type": "Text",
          "config": {
            "label": "CTA Title",
            "placeholder": "Pieteikties uz vizīti"
          }
        },
        "cta_description": {
          "type": "Text",
          "config": {
            "label": "CTA Description",
            "placeholder": "Piesakieties vizītei vai konsultācijai..."
          }
        },
        "cta_button_text": {
          "type": "Text",
          "config": {
            "label": "CTA Button Text",
            "placeholder": "Pieteikties vizītei"
          }
        },
        "cta_link": {
          "type": "Link",
          "config": {
            "label": "CTA URL Link",
            "allowTargetBlank": true
          }
        },
        "cta_link_blank": {
          "type": "Boolean",
          "config": {
            "label": "Open CTA link in new tab",
            "default_value": false,
            "placeholder_true": "Yes",
            "placeholder_false": "No"
          }
        }
      },
      "items": {
        "item_type": {
          "type": "Select",
          "config": {
            "label": "Item Type",
            "options": [
              "Specialization",
              "Education",
              "Qualification",
              "Workplace",
              "Language"
            ],
            "default_value": "Specialization"
          }
        },
        "text": {
          "type": "Text",
          "config": {
            "label": "Text Content",
            "placeholder": "e.g., Dental implants or Latvian"
          }
        }
      }
    }
  ]
}
