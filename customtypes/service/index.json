{
  "id": "service",
  "label": "Service",
  "repeatable": true,
  "status": true,
  "json": {
    "Main": {
      "uid": {
        "type": "UID",
        "config": {
          "label": "UID / URL Slug"
        }
      },
      "title": {
        "type": "Text",
        "config": {
          "label": "Title",
          "placeholder": "Terapeitiskā zobārstniecība"
        }
      },
      "description": {
        "type": "Text",
        "config": {
          "label": "Short Description",
          "placeholder": "Brief service summary..."
        }
      },
      "detailedInfo": {
        "type": "StructuredText",
        "config": {
          "label": "Detailed Info",
          "placeholder": "Long descriptive paragraph of the service...",
          "multi": "paragraph,preformatted,heading2,heading3,strong,em,hyperlink"
        }
      },
      "priceRange": {
        "type": "Text",
        "config": {
          "label": "Price Range",
          "placeholder": "no 60 €"
        }
      },
      "duration": {
        "type": "Text",
        "config": {
          "label": "Duration",
          "placeholder": "30 - 60 min"
        }
      },
      "iconName": {
        "type": "Text",
        "config": {
          "label": "Icon Name (Lucide)",
          "placeholder": "ShieldCheck, Sparkles, Droplet, Scissors, Activity"
        }
      },
      "image": {
        "type": "Image",
        "config": {
          "label": "Service Image",
          "constraint": {},
          "thumbnails": []
        }
      }
    }
  }
}
