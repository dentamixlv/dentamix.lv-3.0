{
  "id": "blog_post",
  "label": "Blog Post",
  "repeatable": true,
  "status": true,
  "json": {
    "Main": {
      "uid": {
        "type": "UID",
        "config": {
          "label": "UID / URL Slug"
        }
      },
      "title": {
        "type": "Text",
        "config": {
          "label": "Title",
          "placeholder": "Kāpēc regulāra mutes higiēna ir labākā investīcija?"
        }
      },
      "category": {
        "type": "Text",
        "config": {
          "label": "Category",
          "placeholder": "MUTES HIGIĒNA"
        }
      },
      "description": {
        "type": "Text",
        "config": {
          "label": "Short Summary Description",
          "placeholder": "Brief description..."
        }
      },
      "detailedContent": {
        "type": "StructuredText",
        "config": {
          "label": "Detailed Article Content",
          "placeholder": "Full paragraphs of the blog post...",
          "multi": "paragraph,preformatted,heading2,heading3,strong,em,hyperlink"
        }
      },
      "image": {
        "type": "Image",
        "config": {
          "label": "Cover Image",
          "constraint": {},
          "thumbnails": []
        }
      },
      "date": {
        "type": "Text",
        "config": {
          "label": "Publication Date String",
          "placeholder": "18. Maijs, 2026"
        }
      },
      "author": {
        "type": "Text",
        "config": {
          "label": "Author Name",
          "placeholder": "Dr. Līga Ozoliņa"
        }
      },
      "readTime": {
        "type": "Text",
        "config": {
          "label": "Reading Time",
          "placeholder": "4 MIN"
        }
      }
    }
  }
}
