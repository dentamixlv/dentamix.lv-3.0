{
  "id": "doctor",
  "label": "Doctor",
  "repeatable": true,
  "status": true,
  "json": {
    "Main": {
      "uid": {
        "type": "UID",
        "config": {
          "label": "UID / URL Slug"
        }
      },
      "name": {
        "type": "Text",
        "config": {
          "label": "Name",
          "placeholder": "Dr. Anna Bērziņa"
        }
      },
      "category": {
        "type": "Text",
        "config": {
          "label": "Category",
          "placeholder": "SPECIĀLISTE or ĶIRURGS"
        }
      },
      "role": {
        "type": "Text",
        "config": {
          "label": "Role",
          "placeholder": "ZOBĀRSTE"
        }
      },
      "description": {
        "type": "Text",
        "config": {
          "label": "Short Description",
          "placeholder": "Short summary of the doctor..."
        }
      },
      "fullBio": {
        "type": "StructuredText",
        "config": {
          "label": "Full Biography",
          "placeholder": "Long professional bio for the detail modal...",
          "multi": "paragraph,preformatted,heading2,heading3,strong,em,hyperlink"
        }
      },
      "image": {
        "type": "Image",
        "config": {
          "label": "Photo",
          "constraint": {},
          "thumbnails": []
        }
      },
      "specializations": {
        "type": "Group",
        "config": {
          "label": "Specializations",
          "fields": {
            "item": {
              "type": "Text",
              "config": {
                "label": "Specialization Item"
              }
            }
          }
        }
      },
      "education": {
        "type": "Group",
        "config": {
          "label": "Education & Courses",
          "fields": {
            "item": {
              "type": "Text",
              "config": {
                "label": "Education Item"
              }
            }
          }
        }
      },
      "languages": {
        "type": "Group",
        "config": {
          "label": "Spoken Languages",
          "fields": {
            "item": {
              "type": "Text",
              "config": {
                "label": "Language"
              }
            }
          }
        }
      },
      "detailedBio": {
        "type": "StructuredText",
        "config": {
          "label": "Detailed Biography (Under Doctor Text)",
          "placeholder": "Enter detailed text like in a blog post...",
          "multi": "paragraph,preformatted,heading2,heading3,strong,em,hyperlink"
        }
      },
      "workplace_title": {
        "type": "Text",
        "config": {
          "label": "Workplace Section Title",
          "placeholder": "Darba vieta"
        }
      },
      "workplaces": {
        "type": "Group",
        "config": {
          "label": "Workplaces",
          "fields": {
            "item": {
              "type": "Text",
              "config": {
                "label": "Workplace Item"
              }
            }
          }
        }
      },
      "qualifications": {
        "type": "Group",
        "config": {
          "label": "Additional Qualifications",
          "fields": {
            "item": {
              "type": "Text",
              "config": {
                "label": "Qualification Item"
              }
            }
          }
        }
      }
    }
  }
}
